{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "custom": {
      "additionalProperties": {},
      "propertyNames": {
        "type": "string"
      },
      "type": "object"
    },
    "id": {
      "type": "string"
    },
    "kind": {
      "enum": [
        "asset",
        "component",
        "style",
        "setup",
        "template",
        "token",
        "utility"
      ],
      "type": "string"
    },
    "layers": {
      "additionalProperties": {
        "items": {
          "additionalProperties": false,
          "properties": {
            "layer": {
              "enum": [
                "examples",
                "interface",
                "full"
              ],
              "type": "string"
            },
            "path": {
              "type": "string"
            }
          },
          "required": [
            "layer",
            "path"
          ],
          "type": "object"
        },
        "type": "array"
      },
      "default": {},
      "propertyNames": {
        "type": "string"
      },
      "type": "object"
    },
    "name": {
      "type": "string"
    },
    "package": {
      "type": "string"
    },
    "relations": {
      "default": [],
      "items": {
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string"
          },
          "type": {
            "enum": [
              "dependsOn",
              "usedBy",
              "partOf",
              "relates"
            ],
            "type": "string"
          }
        },
        "required": [
          "id",
          "type"
        ],
        "type": "object"
      },
      "type": "array"
    },
    "since": {
      "type": "string"
    },
    "sources": {
      "default": [],
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "status": {
      "enum": [
        "stable",
        "beta",
        "experimental",
        "deprecated"
      ],
      "type": "string"
    },
    "tags": {
      "default": [],
      "items": {
        "type": "string"
      },
      "type": "array"
    }
  },
  "required": [
    "id",
    "kind",
    "layers",
    "name",
    "package",
    "relations",
    "since",
    "sources",
    "status",
    "tags"
  ],
  "type": "object"
}
