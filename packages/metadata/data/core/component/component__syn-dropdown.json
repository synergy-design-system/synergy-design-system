    "override": {
      "figmaComponentId": "11573-375949",
      "figmaDocsId": "41203-538934",
      "stories": [
        {
          "description": {
            "type": "text",
            "value": "Dropdowns expose additional content that “drops down” in a panel.Dropdowns consist of a trigger and a panel. By default, activating the trigger will expose the panel and interacting outside of the panel will close it.\n\nDropdowns are designed to work well with menus to provide a list of options the user can select from. However, dropdowns can also be used in lower-level applications (e.g. color picker). The API gives you complete control over showing, hiding, and positioning the panel."
          },
          "name": "default",
          "title": {
            "type": "text",
            "value": "Dropdown"
          }
        },
        {
          "description": {
            "type": "text",
            "value": "When dropdowns are used with menus, you can listen for the syn-select event to determine which menu item was selected. The menu item element will be exposed in event.detail.item. You can set value props to make it easier to identify commands. DEV: Alternatively, you can listen for the click event on individual menu items. Note that, using this approach, disabled menu items will still emit a click event."
          },
          "name": "selected",
          "title": {
            "type": "text",
            "value": "Getting the Selected Item"
          }
        },
        {
          "description": {
            "type": "text",
            "value": "The preferred placement of the dropdown can be set with the placement attribute. Note that the actual position may vary to ensure the panel remains in the viewport."
          },
          "name": "placement",
          "title": {
            "type": "text",
            "value": "Placement"
          }
        },
        {
          "description": {
            "type": "text",
            "value": "The distance from the panel to the trigger can be customized using the distance attribute. This value is specified in pixels."
          },
          "name": "distance",
          "title": {
            "type": "text",
            "value": "Distance"
          }
        },
        {
          "description": {
            "type": "text",
            "value": "The offset of the panel along the trigger can be customized using the skidding attribute. This value is specified in pixels."
          },
          "name": "skidding",
          "title": {
            "type": "text",
            "value": "Skidding"
          }
        },
        {
          "description": {
            "type": "text",
            "value": "To create a submenu, nest an <syn-menu slot=\"submenu\"> element in a menu item."
          },
          "name": "submenu",
          "title": {
            "type": "text",
            "value": "Submenus"
          }
        }
      ],
      "storySourcePath": "components.dropdown",
      "storyTags": [
        "Form"
      ]
    },
    "rules": {
      "accessibility": [
        "Ensure that when the menu is triggered via keyboard, the first item receives focus."
      ],
      "component": "syn-dropdown",
      "related": {
        "templates": [
          "AppShell"
        ]
      },
      "usageGuidelines": [
        {
          "content": [
            "Avoid hiding sets of less than 4 items in dropdowns.",
            "Refrain from nesting dropdowns within each other. If nesting is strictly necessary, limit the menu to two layers to prevent complex operation and cognitive load.",
            "Keep the panel near its trigger so users understand its context."
          ],
          "id": "behavior",
          "name": "Behavior"
        },
        {
          "content": [
            "Group related panel items to make them easier to find, especially if there are many. Use a group label and syn-divider to separate them visually."
          ],
          "id": "panel_items",
          "name": "Panel Items"
        },
        {
          "content": [
            "Maintain consistent styling for dropdown triggers placed at the same level or in the same group; i.e., if a trigger has both text and icon, other triggers on the same level or group should also display text and icon.",
            "Avoid truncating trigger labels if possible."
          ],
          "id": "triggers",
          "name": "Triggers"
        }
      ],
      "useCases": [
        "Provide a list of items in a compact space.",
        "Display additional options or settings related to a specific item.",
        "Enable navigation through different sections or categories."
      ]
    },
    "sourceModulePath": "components/dropdown/dropdown.js",
    "summary": "Dropdowns expose additional content that \"drops down\" in a panel."
  },
