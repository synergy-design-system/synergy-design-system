---
import { Code } from 'astro-expressive-code/components'
import { type SynBadge } from '@synergy-design-system/components';
import {
	experimental_listIntentCategories,
	experimental_getIntentCategory,
	experimental_getIntentOptions,
	experimental_listIntents,
	type IntentTargetRef,
} from '@synergy-design-system/metadata';
import Layout from '../../layouts/Layout.astro';
import ContentFooter from '../../components/ContentFooter.astro';
import ContentHeader from '../../components/ContentHeader.astro';
import Link from '../../components/Link.astro';
import { getIntentTargetPath } from '../../utils/intentTargetPath';
import { metadataStoreOptions } from '../../utils/metadataStoreOptions';

export async function getStaticPaths() {
	const result = await experimental_listIntentCategories(metadataStoreOptions);

	return result.data.map(category => ({
		params: { id: category.id },
		props: {
			categoryId: category.id,
		}
	}));
}

const routeId = Astro.params.id;
const { categoryId } = Astro.props;

if (!routeId) {
	throw new Error('Missing intent policy route parameter.');
}

if (!categoryId) {
	throw new Error('Missing intent policy category id for route.');
}

const category = await experimental_getIntentCategory(categoryId, {}, metadataStoreOptions);

const intents = await experimental_listIntents({
	category: categoryId,
	includePhases: ['experimental'],
}, metadataStoreOptions);

const renderFrameworks = [
	'vanilla',
	'react-wrapper',
	'react-web-components',
	'angular',
	'vue',
] as const;

const variantsByIntentId = new Map(
	await Promise.all(intents.data.map(async intent => {
		const defaultTargetIds = new Set<string>();
		const variantResults = await Promise.all(renderFrameworks.map(async framework => {
			const options = await experimental_getIntentOptions({
				framework,
				includePhases: ['experimental'],
				intentId: intent.id,
				maxAlternatives: 20,
			}, metadataStoreOptions);

			if (options.data?.bestDefaultTargetId) {
				defaultTargetIds.add(options.data.bestDefaultTargetId);
			}

			return [framework, options.data?.renderableTargets ?? []] as const;
		}));

		const variantMap = new Map<string, {
			isDefault: boolean;
			priority?: number;
			reason: string;
			target: IntentTargetRef;
			targetRole?: 'standalone' | 'container' | 'item';
			previews: Array<readonly [typeof renderFrameworks[number], string]>;
		}>();

		for (const [framework, targets] of variantResults) {
			for (const target of targets) {
				const targetRef: IntentTargetRef = {
					id: target.targetId,
					kind: target.targetId.startsWith('style:') ? 'style' : 'component',
					name: target.targetName,
				};

				const existing = variantMap.get(target.targetId);
				if (existing) {
					existing.isDefault = existing.isDefault || defaultTargetIds.has(target.targetId);
					existing.priority = Math.max(existing.priority ?? 0, target.priority ?? 0);
					existing.targetRole = existing.targetRole ?? target.targetRole;
					existing.previews.push([framework, target.previewCode] as const);
					continue;
				}

				variantMap.set(target.targetId, {
					isDefault: defaultTargetIds.has(target.targetId),
					priority: target.priority,
					previews: [[framework, target.previewCode] as const],
					reason: target.reason,
					target: targetRef,
					targetRole: target.targetRole,
				});
			}
		}

		const getTargetRoleWeight = (targetRole?: 'standalone' | 'container' | 'item') => {
			switch (targetRole ?? 'standalone') {
				case 'standalone':
					return 3;
				case 'container':
					return 2;
				case 'item':
					return 1;
				default:
					return 0;
			}
		};

		const variants = Array.from(variantMap.values())
			.sort((a, b) => {
				if (a.isDefault !== b.isDefault) {
					return a.isDefault ? -1 : 1;
				}

				const roleWeightDiff = getTargetRoleWeight(b.targetRole) - getTargetRoleWeight(a.targetRole);
				if (roleWeightDiff !== 0) {
					return roleWeightDiff;
				}

				const priorityDiff = (b.priority ?? 0) - (a.priority ?? 0);
				if (priorityDiff !== 0) {
					return priorityDiff;
				}

				const aLabel = a.target.id ?? a.target.name ?? a.target.selector ?? a.target.kind;
				const bLabel = b.target.id ?? b.target.name ?? b.target.selector ?? b.target.kind;

				return aLabel.localeCompare(bLabel);
			});

		return [intent.id, variants] as const;
	})),
);

const nowIso = new Date().toISOString();

const formatTarget = (target: IntentTargetRef): string => {
	if (target.id) {
		return target.id;
	}

	if (target.name) {
		return `${target.kind}:${target.name}`;
	}

	if (target.selector) {
		return `${target.kind}:${target.selector}`;
	}

	if (target.classes && target.classes.length > 0) {
		return `${target.kind}:.${target.classes.join('.')}`;
	}

	return target.kind;
};

const getDescriptionForPhase = (phase: string): string => {
	switch (phase) {
		case 'deprecated':
			return 'This intent is deprecated and may be removed in future releases. Use with caution.';
		case 'experimental':
			return 'This intent is experimental and may change or be removed in future releases. Use with caution.';
		case 'stable':
			return 'This intent is stable and ready for production use.';
		default:
			return '';
	}
};

const getPhaseBadge = (phase: string): SynBadge['variant'] => {
	switch (phase) {
		case 'deprecated':
			return 'danger';
		case 'experimental':
			return 'warning';
		case 'stable':
			return 'success';
		default:
			return 'neutral';
	}
};
---

<Layout>
	<syn-card shadow>
		<ContentHeader headline={`Intent Policy: ${category.data!.id}`}>
			{category.data!.phase && (
				<syn-tooltip content={getDescriptionForPhase(category.data!.phase)}>
					<syn-badge variant={getPhaseBadge(category.data!.phase)}>{category.data!.phase}</syn-badge>
				</syn-tooltip>
			)}
		</ContentHeader>

		<h2 class="syn-heading--2x-large">Description</h2>
		<p>{category.data!.description}</p>

		<h2 class="syn-heading--2x-large">Intents</h2>
		{intents.data.length > 0 && (
			<>
				{intents.data.map(intent => {
					const variants = variantsByIntentId.get(intent.id) ?? [];
					return (
						<syn-card sharp>
							<h3 class="syn-heading--large" slot="header">
								{intent.id}
								{intent.phase && (
									<syn-tooltip content={getDescriptionForPhase(intent.phase)}>
										<syn-badge variant={getPhaseBadge(intent.phase)}>{intent.phase}</syn-badge>
									</syn-tooltip>
								)}
							</h3>

							<ul>
								<li>
									<strong>Description</strong>
									{intent.description}
								</li>
								<li>
									<strong>User Goal</strong>
									{intent.userGoal}
								</li>
								<li>
									<strong>Linked Targets</strong>
									{variants.length > 0 ? (
										<ul>
											{variants.map(variant => (
													<li>
														{(() => {
															const targetLabel = formatTarget(variant.target);
															const targetPath = getIntentTargetPath(variant.target);

															if (!targetPath) {
																return targetLabel;
															}

															return (
																<Link href={targetPath}>
																	<syn-badge>Uses</syn-badge>
																	{targetLabel}
																</Link>
															);
														})()}
													</li>
											))}
										</ul>
									) : (
										<span> No linked targets found.</span>
									)}
								</li>
							</ul>

							<h4 class="syn-heading--medium">Variants</h4>
							{variants.length > 0 ? (
								<>
									{variants.map(variant => (
										<>
											<strong>{formatTarget(variant.target)}</strong>
											{variant.isDefault && <syn-badge variant="success">Default</syn-badge>}
											<p>{variant.reason}</p>

											<syn-tab-group>
												{variant.previews.map(([framework, output]) => (
													<syn-tab-panel name={framework}>
														<Code code={output} lang="html" />
													</syn-tab-panel>
													<syn-tab panel={framework} slot="nav">
														{framework}
													</syn-tab>
												))}
											</syn-tab-group>
										</>
									))}
								</>
							) : (
								<span> No previews available.</span>
							)}
						</syn-card>
						<syn-divider />
					);
				})}
			</>
		)}

		<ContentFooter
			creationDate={nowIso}
			entityId={routeId}
		/>
	</syn-card>
</Layout>
