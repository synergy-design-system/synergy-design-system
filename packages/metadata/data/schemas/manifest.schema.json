{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "buildInfo": {
      "type": "object",
      "properties": {
        "branch": {
          "type": "string"
        },
        "ci": {
          "type": "boolean"
        },
        "commit": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "builtAt": {
      "type": "string",
      "format": "date-time",
      "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z))$"
    },
    "checksums": {
      "type": "object",
      "propertyNames": {
        "type": "string"
      },
      "additionalProperties": {
        "type": "string"
      }
    },
    "sources": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "entityCount": {
            "type": "number"
          },
          "error": {
            "type": "string"
          },
          "source": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "success",
              "partial",
              "failed"
            ]
          }
        },
        "required": [
          "source",
          "status"
        ],
        "additionalProperties": false
      }
    },
    "synergyVersion": {
      "type": "string"
    },
    "version": {
      "type": "string"
    }
  },
  "required": [
    "builtAt",
    "version"
  ],
  "additionalProperties": false
}
