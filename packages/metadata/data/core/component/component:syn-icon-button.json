        },
        {
          "description": {
            "type": "text",
            "value": "A description that gets read by assistive devices. For optimal accessibility, you have to include a label that describes what the icon button does."
          },
          "name": "label",
          "title": {
            "type": "text",
            "value": "Accessibility Label"
