{
  "author": {
    "name": "SICK Global UX Foundation",
    "url": "https://www.sick.com"
  },
  "description": "Metadata for the Synergy Design System, usable by MCP Servers or other AI tools",
  "devDependencies": {
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "@synergy-design-system/components": "workspace:*",
    "@synergy-design-system/docs": "workspace:*",
    "@synergy-design-system/eslint-config-syn": "workspace:^",
    "@synergy-design-system/fonts": "workspace:*",
    "@synergy-design-system/styles": "workspace:*",
    "@synergy-design-system/tokens": "workspace:^",
    "@types/node": "^24.12.0",
    "@types/serve-handler": "^6.1.4",
    "chai": "^5.2.0",
    "custom-elements-manifest": "^2.1.0",
    "eslint": "^9.39.4",
    "execa": "^9.6.0",
    "playwright": "^1.58.2",
    "prettier": "^3.8.1",
    "rimraf": "^6.1.3",
    "serve-handler": "^6.1.7",
    "typescript": "^5.9.3",
    "zod": "^4.3.6"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./public": {
      "types": "./dist/public/index.d.ts",
      "default": "./dist/public/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "data/**",
    "dist/index.d.ts",
    "dist/index.js",
    "dist/public/**",
    "README.md",
    "CHANGELOG.md"
  ],
  "homepage": "https://github.com/synergy-design-system/synergy-design-system/tree/main/packages/metadata",
  "keywords": [
    "SDS",
    "Synergy Design System",
    "SICK",
    "SICK Design System",
    "UI",
    "UI Metadata Server",
    "Synergy Metadata"
  ],
  "license": "MIT",
  "main": "./dist/index.js",
  "name": "@synergy-design-system/metadata",
  "repository": {
    "type": "git",
    "url": "https://github.com/synergy-design-system/synergy-design-system.git",
    "directory": "packages/metadata"
  },
  "scripts": {
    "build:all": "METADATA_LOG_LEVEL=info pnpm run build:ts && RUN_STORYBOOK_SCRAPER=true pnpm run build:data",
    "build": "METADATA_LOG_LEVEL=info pnpm run build:ts && pnpm run build:data",
    "build:data": "node dist/internal/cli/build.js",
    "build:ts": "tsc && tsc -p tsconfig.rules.json",
    "clean": "rimraf dist && ( [ -d data ] && find data -type f ! -name '.gitkeep' -delete && find data -type d -empty -delete || true )",
    "lint:js": "eslint src config",
    "lint:schemas": "node src/internal/cli/schema-lint.js",
    "lint": "pnpm run /^lint:.*/",
    "pretest": "pnpm run build:ts",
    "test": "node --test --test-timeout=15000 test/**/*.test.mjs"
  },
  "types": "./dist/index.d.ts",
  "type": "module",
  "version": "3.0.0"
}
