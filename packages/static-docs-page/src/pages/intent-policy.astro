---
import {
	experimental_findComponentsForTask,
	experimental_getComponentGuide,
	experimental_getIntentOptions,
	experimental_listIntentCategories,
	experimental_validateComponent,
} from '@synergy-design-system/metadata';
import Layout from '../layouts/Layout.astro';
import ContentFooter from '../components/ContentFooter.astro';
import ContentHeader from '../components/ContentHeader.astro';
import { metadataStoreOptions } from '../utils/metadataStoreOptions';

const includePhases = ['experimental'] as const;

const categories = await experimental_listIntentCategories(
	metadataStoreOptions,
	{ includePhases: [...includePhases] },
);

const componentGuide = await experimental_getComponentGuide({
	component: 'syn-button',
	framework: 'react-web-components',
	includePhases: [...includePhases],
}, metadataStoreOptions);

const componentValidation = await experimental_validateComponent({
	component: 'syn-button',
	framework: 'react-web-components',
	includePhases: [...includePhases],
	intent: 'action.submit',
	props: {
		disabled: true,
		href: '#',
	},
}, metadataStoreOptions);

const taskRecommendations = await experimental_findComponentsForTask({
	framework: 'react-web-components',
	includePhases: [...includePhases],
	taskId: 'action.submit',
}, metadataStoreOptions);

const intentOptions = await experimental_getIntentOptions({
	framework: 'react-web-components',
	includePhases: [...includePhases],
	intentId: 'navigation.link-list.grouped',
}, metadataStoreOptions);

const nowIso = new Date().toISOString();
---

<Layout>
	<syn-card shadow>
		<ContentHeader headline="Intent Policy Overview" />

		<p>
			This page demonstrates the developer-friendly intent APIs in one place using live metadata queries.
		</p>

		<h2 class="syn-heading--large">Active Intent Categories</h2>
		<p>Loaded with phase filter: <strong>{includePhases.join(', ')}</strong></p>
		<pre><code>{JSON.stringify(categories.data.map((category) => category.id), null, 2)}</code></pre>

		<h2 class="syn-heading--large">API: getComponentGuide</h2>
		<p>Question: What can I do with <strong>syn-button</strong>?</p>
		<pre><code>{JSON.stringify(componentGuide.data, null, 2)}</code></pre>

		<h2 class="syn-heading--large">API: validateComponent</h2>
		<p>Question: Do I use <strong>syn-button</strong> right for <strong>action.submit</strong>?</p>
		<pre><code>{JSON.stringify(componentValidation.data, null, 2)}</code></pre>

		<h2 class="syn-heading--large">API: findComponentsForTask</h2>
		<p>Question: What does Synergy provide to submit a form?</p>
		<pre><code>{JSON.stringify(taskRecommendations.data, null, 2)}</code></pre>

		<h2 class="syn-heading--large">API: getIntentOptions</h2>
		<p>Question: What are my renderable options for a specific intent?</p>
		<pre><code>{JSON.stringify(intentOptions.data, null, 2)}</code></pre>

		<ContentFooter
			creationDate={nowIso}
			entityId={null}
		/>
	</syn-card>
</Layout>
