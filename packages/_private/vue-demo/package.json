{
  "name": "@synergy-design-system/demo-vue",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "start": "pnpm run dev",
    "dev": "vite",
    "preview": "vite preview",
    "_build": "vite build",
    "type-check": "vue-tsc --noEmit -p tsconfig.app.json --composite false",
    "lint:html": "html-validate index.html",
    "lint:js": "eslint .",
    "lint": "pnpm run /^lint:.*/",
    "format.eslint": "pnpm lint:js --fix",
    "format": "prettier --write src/"
  },
  "dependencies": {
    "@synergy-design-system/assets": "workspace:*",
    "@synergy-design-system/components": "workspace:*",
    "@synergy-design-system/demo-utilities": "workspace:*",
    "@synergy-design-system/fonts": "workspace:*",
    "@synergy-design-system/styles": "workspace:*",
    "@synergy-design-system/tokens": "workspace:*",
    "@synergy-design-system/vue": "workspace:*",
    "vue": "^3.5.33",
    "vue-router": "^5.0.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@tsconfig/node24": "^24.0.4",
    "@types/node": "^24.12.2",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vue/tsconfig": "^0.9.1",
    "eslint": "^9.39.4",
    "eslint-plugin-vue": "^10.9.0",
    "globals": "^17.5.0",
    "html-validate": "^10.13.1",
    "prettier": "^3.8.3",
    "typescript": "~5.9.3",
    "vite": "^8.0.10",
    "vite-plugin-static-copy": "^4.1.0",
    "vue-eslint-parser": "^10.4.0",
    "vue-tsc": "^3.2.7"
  },
  "type": "module"
}
